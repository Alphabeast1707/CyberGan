# Environment / secrets — NEVER commit these
.env
*.env
!.env.example

# Trained model weights (large files — mount as volumes in prod)
# Uncomment the next two lines if you want to exclude checkpoints from git
# checkpoints/*.pt
# config/checkpoints/*.pt

# Keep the checkpoint directory but ignore large .pt files
checkpoints/*.pt
config/checkpoints/*.pt

# Keep training metadata and logs
!config/checkpoints/.gitkeep
!config/logs/.gitkeep

# Logs
logs/
*.log
config/logs/*.json

