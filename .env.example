# CyberGAN — Environment Variables
# Copy this to .env and fill in your credentials
# NEVER commit .env to git

# ── Agent Mode ─────────────────────────────────
# advisory   = alert only, never block
# autonomous = RL policy acts automatically
# hybrid     = RL policy + human override threshold
CYBERGAN_MODE=hybrid

# ── Dashboard ──────────────────────────────────
DASHBOARD_PORT=8443
CYBERGAN_LOG_LEVEL=INFO

# ── Alert Integrations (optional) ─────────────
# Paste your webhook URLs here to get real-time Slack/Discord alerts
SLACK_WEBHOOK=
DISCORD_WEBHOOK=
PAGERDUTY_KEY=
